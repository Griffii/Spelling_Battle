[node name="HowTo_English" type="Label" parent="Board_Canvas/HelpCanvasLayer/HowToContainer/NinePatchRect/MarginContainer/HelpVBox/HBoxContainer" unique_id=720532370]
custom_minimum_size = Vector2(600, 600)
layout_mode = 2
size_flags_horizontal = 4
theme_override_fonts/font = ExtResource("5_hl2y5")
theme_override_font_sizes/font_size = 32
text = "・Rock-Paper-Scissors to decide who goes first.
・Press \"DUEL\" to start.
・A category appears.
・・Each player has 30 seconds to type an English word that fits.
・・It must be spelled correctly.
・Then the battle begins:
・・Fireballs launch from the center.
・・More consonants = faster fireballs.
・If a fireball reaches the end, it explodes and deals 1 damage.
・・Each player has 3 lives.
・・Lose all 3 = game over.
・Player 1's fireballs move first"
autowrap_mode = 3

[node name="HowTo_Japanese" type="Label" parent="Board_Canvas/HelpCanvasLayer/HowToContainer/NinePatchRect/MarginContainer/HelpVBox/HBoxContainer" unique_id=2031223488]
custom_minimum_size = Vector2(600, 600)
layout_mode = 2
size_flags_horizontal = 4
theme_override_fonts/font = ExtResource("7_hrnlr")
theme_override_font_sizes/font_size = 30
text = "・最初にじゃんけんで先攻を決めます。
・「DUEL」ボタンを押してゲームを開始。
・お題が表示されます。
・・各プレイヤーは30秒以内に、お題に合う英単語を入力します。
・・単語は正しく綴られている必要があります。
・その後、バトル開始！
・ファイアボールが中央から相手側に発射されます。
・子音の数が多いほど、ファイアボールが多く進みます。
・ファイアボールが相手の端に到達すると、爆発して1ダメージを与えます。
・・各プレイヤーのライフは3つ。
・・ライフが0になるとゲームオーバーです。
・先攻のプレイヤーのファイアボールが先に動くため、先攻は有利です！"
autowrap_mode = 3

